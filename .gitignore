# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Optional local override for secrets. Anything in `secrets.env` overrides
# values from the decrypted SOPS files in secrets/.
secrets.env

# Plaintext leak guard: sops --decrypt or partial encryption can leave
# unencrypted JSON in secrets/. Block any *.json under secrets/ that
# isn't the encrypted .sops.json form so `git add -A` can't ever pick
# up plaintext secrets.
/secrets/*.json
!/secrets/*.sops.json
/dev.toml
/dev.toml.local
/dev/

# Local notes / scratch.
deployments.txt

# Terraform: provider plugin cache and plan artefacts. State is committed
# (matching the infra repo's convention).
.terraform/
*.tfplan
*.tfstate.backup

# Supabase CLI workspace artifacts (ephemeral; regenerated by `supabase link`).
supabase/.temp/
dash/supabase/
