[Unit]
Description=LED matrix WiFi onboarding (AP + captive portal until configured)
After=NetworkManager.service
Wants=NetworkManager.service
Before=network-online.target led-tailscale-init.service
# led-driver intentionally NOT in `Before=` — it runs concurrently
# and renders the setup frame (or boot frame) until this service
# finishes and the panel state syncs.

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=/etc/led/init.env
ExecStart=/usr/local/bin/led-wifi-setup --id ${PANEL_ID} --country ${WIFI_COUNTRY}

[Install]
WantedBy=multi-user.target
