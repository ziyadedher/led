# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Optional local override for secrets (`secrets.sops.env` is the source of
# truth, committed encrypted). Anything in `secrets.env` overrides values
# from the decrypted SOPS file.
secrets.env

# Local notes / scratch.
deployments.txt

# Terraform: provider plugin cache and plan artefacts. State is committed
# (matching the infra repo's convention).
.terraform/
*.tfplan
*.tfstate.backup

# Supabase CLI workspace artifacts (ephemeral; regenerated by `supabase link`).
supabase/.temp/
dash/supabase/
