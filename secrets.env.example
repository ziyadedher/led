# Copy this file to `secrets.env` and fill it in. `secrets.env` is gitignored
# and consumed by the justfile via `set dotenv-load`.

# Supabase PostgREST URL. Form: https://<project>.supabase.co/rest/v1
SUPABASE_URL=

# Supabase anon JWT. Find it under Project Settings -> API -> Project API keys.
SUPABASE_ANON_KEY=

# OTLP/HTTP endpoint for telemetry export. Leave blank to disable.
# Typical value over the tailnet: http://infra:4318
OTEL_ENDPOINT=
