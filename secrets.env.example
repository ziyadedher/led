# Copy to `secrets.env` and fill in. `secrets.env` is gitignored and
# consumed by the justfile via `set dotenv-load`.

# --- driver runtime ---

# Supabase PostgREST URL. Form: https://<project>.supabase.co/rest/v1
SUPABASE_URL=

# Supabase anon JWT. Project Settings -> API -> Project API keys.
SUPABASE_ANON_KEY=

# OTLP/HTTP endpoint for telemetry export. Empty disables export.
# Typical value over the tailnet: http://infra:4318
OTEL_ENDPOINT=

# --- SD provisioning (only needed for `just flash-sd`) ---

# WiFi network the matrix will join. PSK-only WPA2 is assumed.
WIFI_SSID=
WIFI_PSK=
WIFI_COUNTRY=US

# Reusable Tailscale auth key (Settings -> Keys -> Generate auth key, mark it
# reusable + non-ephemeral). Each flashed Pi consumes one ephemeral use.
TAILSCALE_AUTHKEY=

# Public SSH key authorized to log into the `pi` user. Defaults to
# ~/.ssh/id_ed25519.pub if unset.
SSH_AUTHORIZED_KEYS_FILE=
